{
  "name": "flowbite-vue",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/themesberg/flowbite-vue.git"
  },
  "author": "themesberg",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/flowbite-vue.umd.cjs",
  "module": "./dist/flowbite-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/flowbite-vue.js",
      "require": "./dist/flowbite-vue.umd.cjs"
    },
    "./components/*/types": {
      "types": "./dist/components/*/types.d.ts"
    },
    "./index.css": "./dist/index.css"
  },
  "scripts": {
    "dev": "vitepress dev docs",
    "start": "vitepress serve docs --port $PORT",
    "build": "vitepress build docs && cp -r ./docs/assets/* ./docs/.vitepress/dist/assets/",
    "build:package": "vite build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly && tsc-alias -p tsconfig.json",
    "build:production": "npm run build:package && npm run build:types",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "clear": "rm -fr ./dist && rm -fr ./dist_types && rm -fr ./docs/.vitepress/dist && rm -fr ./docs/.vitepress/cache",
    "format": "npm run lint-fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build:production"
  },
  "peerDependencies": {
    "vue": "^3.5.x"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.9",
    "@vue/eslint-config-typescript": "14.8.0",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "10.9.2",
    "eslint-plugin-vue-scoped-css": "^3.1.1",
    "jsdom": "^29.1.1",
    "neostandard": "^0.13.0",
    "tsc-alias": "1.8.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitepress": "1.6.4",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@vueuse/core": "14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "floating-vue": "^5.2.2",
    "flowbite": "4.0.2",
    "lodash-es": "^4.18.1",
    "nanoid": "5.1.15",
    "postcss-prefix-selector": "^2.1.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.x"
  }
}
